PROJECT_NAME=ZedUploader
BOT_TOKEN=put_bot_token_here
BOT_USERNAME=your_bot_username
ADMIN_IDS=123456789
DOMAIN=https://example.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=change_this_secret
DATABASE_URL=postgresql+asyncpg://uploader:uploader_password@db:5432/uploader_bot
REDIS_URL=redis://redis:6379/0
API_KEY=change_this_api_key
JWT_SECRET=change_this_jwt_secret
SESSION_SECRET=change_this_session_secret
PANEL_PATH=/panel
CENTRALPAY_GETLINK_KEY=
CENTRALPAY_VERIFY_KEY=
DEFAULT_PROTECT_CONTENT=false
DEFAULT_AUTO_DELETE_SECONDS=0
DEFAULT_PLAN=free
BOT_MODE=webhook
LOG_LEVEL=INFO
LICENSE_KEY=
LICENSE_SERVER_URL=
LICENSE_GRACE_DAYS=7
LICENSE_DISABLED=true
# Multi-tenant (Phase F): Fernet key to encrypt hosted bot tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TENANT_TOKEN_KEY=
POSTGRES_USER=uploader
POSTGRES_PASSWORD=uploader_password
POSTGRES_DB=uploader_bot
